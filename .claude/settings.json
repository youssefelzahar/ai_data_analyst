{
  "permissions": {
    "allow": [
      "Bash(curl -s -o /dev/null -w \"backend:%{http_code}\\\\n\" http://localhost:8000/api/v1/health)",
      "Bash(curl -s -o /dev/null -w \"frontend:%{http_code}\\\\n\" http://localhost:3001/data-sources)",
      "Bash(curl -s http://127.0.0.1:8010/api/v1/health)",
      "Bash(powershell -NoProfile -Command 'Get-NetTCPConnection -LocalPort 3010 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }')"
    ]
  }
}

# Copy this file to .env and adjust values. Never commit .env.

APP_NAME="AI Data Analyst"
ENVIRONMENT=development
DEBUG=true

# JSON array — pydantic-settings parses list fields as JSON
CORS_ORIGINS=["http://localhost:3000"]

# Application metadata store. SQLite for local dev; in Docker this is
# overridden with a PostgreSQL URL (postgresql+psycopg://...).
DATABASE_URL=sqlite:///./ai_data_analyst.db

# Used to encrypt stored data source credentials. Set a long random value.
SECRET_KEY=change-me-in-production

# --- Authentication / JWT ---
# Signing key for JWTs. Leave empty to reuse SECRET_KEY. Use a long random
# value (>= 32 bytes) in production.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap admin + company, seeded once on first startup (idempotent).
# Change the password before deploying.
BOOTSTRAP_COMPANY_NAME="Default Company"
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# Bootstrap superadmin (platform owner). Its only capability is creating admins.
# Change the password before deploying.
BOOTSTRAP_SUPERADMIN_USERNAME=youssefelzahar
BOOTSTRAP_SUPERADMIN_PASSWORD=123456
BOOTSTRAP_SUPERADMIN_COMPANY=ai_analysis

UPLOAD_DIRECTORY=./uploaded_files
MAX_UPLOAD_SIZE_MB=200

# AI / LLM settings
AI_PROVIDER=ollama
AI_DEFAULT_MODEL=gemma4
AI_TEMPERATURE=0.1
AI_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_BASE_URL=http://localhost:11434
